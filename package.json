{
  "name": "gamebox-platform",
  "version": "0.1.0",
  "private": true,
  "description": "游戏盒子平台 · 多游戏品类 + 多级代理分销 · 仅积分模式 · 学习用途",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:server": "pnpm --filter @gamebox/server start:dev",
    "build:server": "pnpm --filter @gamebox/server build",
    "dev:app": "pnpm --filter @gamebox/client-app dev",
    "build:app": "pnpm --filter @gamebox/client-app build",
    "dev:admin": "pnpm --filter @gamebox/admin-panel dev",
    "build:admin": "pnpm --filter @gamebox/admin-panel build",
    "db:generate": "pnpm --filter @gamebox/server prisma:generate",
    "db:migrate": "pnpm --filter @gamebox/server prisma:migrate",
    "db:seed": "pnpm --filter @gamebox/server prisma:seed",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
