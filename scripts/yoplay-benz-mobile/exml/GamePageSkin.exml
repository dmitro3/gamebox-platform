	<e:Rect id="loadingMask" left="0" right="0" top="0" bottom="0" fillAlpha="0.8" visible="false" locked="true"/>
	<YP:YoPlayLoadingGroup id="loadingGroup" left="0" right="0" top="0" bottom="0" visible="false" locked="true"/>
